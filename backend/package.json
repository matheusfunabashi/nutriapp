{
  "name": "sage-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sage backend proxy — Cloudflare Worker: OFF/Go-UPC lookup + cache, LLM explanations, free-tier usage.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply sage --local",
    "migrate:remote": "wrangler d1 migrations apply sage --remote"
  },
  "dependencies": {
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.78.0"
  }
}
